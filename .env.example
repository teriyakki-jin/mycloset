# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://closetiq:closetiq_dev@localhost:5432/closetiq
DATABASE_URL_SYNC=postgresql://closetiq:closetiq_dev@localhost:5432/closetiq

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage (S3-compatible / MinIO for dev) ───────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=closetiq-uploads
S3_REGION=us-east-1

# ── AI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxx

# ── Next.js (apps/web/.env.local) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ClosetIQ
